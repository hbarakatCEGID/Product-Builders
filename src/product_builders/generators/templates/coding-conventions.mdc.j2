description: "Enforce coding conventions and naming patterns when writing {{ profile.tech_stack.primary_language or '' }} code in {{ profile.metadata.name }}"
globs:
{% if profile.tech_stack.primary_language == 'Python' %}
  - "**/*.py"
{% elif profile.tech_stack.primary_language == 'TypeScript' %}
  - "**/*.ts"
  - "**/*.tsx"
{% elif profile.tech_stack.primary_language == 'JavaScript' %}
  - "**/*.js"
  - "**/*.jsx"
{% elif profile.tech_stack.primary_language == 'Java' %}
  - "**/*.java"
{% elif profile.tech_stack.primary_language == 'C#' %}
  - "**/*.cs"
{% endif %}
alwaysApply: false
priority: 30
